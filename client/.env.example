# ── CampusKey Frontend — Environment Variables ─────────────────────────────
# Local dev: no file needed (defaults to localhost:3001)
# Production: create client/.env.production with your Render URL

# Backend API URL
# Local:      (leave unset — defaults to http://localhost:3001)
# Production: set to your Render service URL
VITE_API_URL=https://campuskey-api.onrender.com
