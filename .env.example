# ── CampusKey Backend — Environment Variables ──────────────────────────────
# Copy to .env for local dev. Set these as Render environment variables in prod.

# Server
PORT=3001
NODE_ENV=development

# WebAuthn — MUST match the frontend origin exactly
# Local:       ORIGIN=http://localhost:3000   RP_ID=localhost
# Production:  ORIGIN=https://campuskey.vercel.app  RP_ID=campuskey.vercel.app
ORIGIN=http://localhost:3000
RP_ID=localhost
RP_NAME=Campus Passkey

# JWT — generate a strong secret for production:  openssl rand -base64 48
JWT_SECRET=campuskey-dev-secret-CHANGE-IN-PROD
JWT_TTL=24h

# Bootstrap code for passkey enrolment
ADMIN_CODE=ADMIN123

# Shared college passkeys (legacy fallback — still works after email verification migration)
STUDENT_PASSKEY=Ruas@123
FACULTY_PASSKEY=RuasF@123

# Email verification via Gmail SMTP — works for ANY recipient email address
# Setup (5 minutes):
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: Google Account → Security → App Passwords
#   3. Create an app password (select "Mail" + "Other")
#   4. Copy the 16-character password into GMAIL_APP_PASSWORD below
# If not set, verification codes are printed to the server console (dev fallback)
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
